# Volcengine Ark model endpoint
ARK_MODEL_ID=ep-xxxxxxxxxxxxxxxx

# Preferred authentication mode
ARK_API_KEY=

# Alternative AK/SK authentication mode; configure both or neither
ARK_ACCESS_KEY=
ARK_SECRET_KEY=

# Optional Ark settings
ARK_BASE_URL=
ARK_REGION=
ARK_TIMEOUT=60s
ARK_RETRY_TIMES=2
ARK_THINKING=auto
ARK_MAX_TOOL_CALLS=8
ARK_PARALLEL_TOOL_CALLS=true

# OpsPilot runtime settings
OPSPILOT_HTTP_ALLOW_PRIVATE=false
OPSPILOT_SYSTEM_PROMPT=
