# Volcengine Ark model endpoint
ARK_MODEL_ID=ep-xxxxxxxxxxxxxxxx

# Preferred authentication mode
ARK_API_KEY=

# Alternative AK/SK authentication mode; configure both or neither
ARK_ACCESS_KEY=
ARK_SECRET_KEY=

# Optional Ark settings
ARK_BASE_URL=
ARK_REGION=
ARK_TIMEOUT=60s
ARK_RETRY_TIMES=2
ARK_THINKING=auto
ARK_MAX_TOOL_CALLS=8
ARK_PARALLEL_TOOL_CALLS=true

# OpsPilot runtime settings
OPSPILOT_HTTP_ALLOW_PRIVATE=false
OPSPILOT_TLS_ALLOW_PRIVATE=false
OPSPILOT_DOCKER_SOCKET=/var/run/docker.sock
OPSPILOT_KUBECONFIG=
OPSPILOT_KUBERNETES_CONTEXT=
OPSPILOT_PROMETHEUS_URL=
OPSPILOT_PROMETHEUS_ALLOW_HTTP=false
OPSPILOT_PROMETHEUS_BEARER_TOKEN_FILE=
OPSPILOT_SYSTEM_PROMPT=
OPSPILOT_EVENTS=none

# Optional OpenTelemetry OTLP/HTTP tracing
OPSPILOT_OTEL_ENABLED=false
OTEL_SERVICE_NAME=opspilot
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
